msgstr "Присоединяйтесь к сообществу Deepland."

msgid "By signing up, you agree to our"
msgstr "Регистрируясь, вы соглашаетесь с нашими"

msgid "and"
msgstr "и"

msgid "Already have an account?"
msgstr "Уже есть аккаунт?"

